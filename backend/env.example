# ─────────────────────────────────────────────
# SETU Backend — Environment Variables
# Copy this file to .env and fill in your values
# Never commit your actual .env file
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# For Docker: use the service name 'db' as the host
# For local: use 'localhost'
DATABASE_URL=postgresql://setu_user:setu_dev_password@db:5432/setu

# ── Server ────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Authentication ────────────────────────────
# Generate a strong random secret — do NOT use this default in production
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Email Notifications (Nodemailer) ──────────
# Leave blank to disable email notifications in development
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
SMTP_FROM=SETU Notifications <no-reply@setu.app>

# ── Frontend URL (for CORS) ───────────────────
FRONTEND_URL=http://localhost:3000
